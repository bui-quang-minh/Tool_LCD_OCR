# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Node / Next.js ────────────────────────────────────────────────────────────
ui/node_modules/
ui/.next/
ui/out/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
backend/.env

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Agent skills ──────────────────────────────────────────────────────────────
.agents/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── MLflow / Airflow ──────────────────────────────────────────────────────────
mlruns/
mlartifacts/
logs/
*.log

# ── Tests ─────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Model weights (tracked via Git LFS instead) ───────────────────────────────
*.node
infra/.env

# ── Model weights: theo dõi trực tiếp trong Git (mỗi file <100MB) ────────────
# (không dùng Git LFS để tránh yêu cầu cài thêm công cụ khi thầy/người khác clone)

# ── Runtime data không nên track (log sinh ra lúc chạy, dataset đặt tay) ─────
infra/airflow/logs/*
!infra/airflow/logs/.gitkeep
data/lcd_dataset/*
!data/lcd_dataset/.gitkeep
