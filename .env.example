# ============================================================
# LCD-OCR MLOps Stack — biến môi trường mẫu
# Copy file này thành ".env" rồi điền giá trị thật trước khi
# chạy: cp .env.example .env
# File ".env" KHÔNG được đưa lên Git (đã có trong .gitignore).
# ============================================================

# --- Địa chỉ public để frontend gọi backend, và CORS ---
# Deploy trên máy cá nhân / localhost thì để nguyên mặc định.
# Deploy lên server thật thì đổi thành IP/domain thật của server.
PUBLIC_HOST=localhost
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]

# --- PostgreSQL (dùng chung cho Airflow metadata) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=airflow

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme
AIRFLOW_UID=50000

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Backend (lcd_be) ---
USE_MLFLOW_REGISTRY=false
USE_MLFLOW_TRACKING=false

# --- Dataset dùng để (re)train — CHỈ cần nếu muốn chạy lại Airflow DAG train.
# Không cần cho việc chạy inference /predict (model đã đóng gói sẵn trong image).
# Mặc định trỏ về đường dẫn cũ trên server gốc để không phá vỡ hệ thống đang chạy.
# Deploy máy mới: đặt dataset vào thư mục ./data rồi đổi biến này thành ./data
LCD_DATASET_DIR=./data/lcd_dataset
