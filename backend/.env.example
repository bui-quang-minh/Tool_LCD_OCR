# ── Core ──────────────────────────────────────────────────────────────────────
# Override model paths if you place weights somewhere else
# DETECTION_MODEL=./models/detection.pt
# OCR_MODEL=./models/ocr.pt
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_DETECTION_MODEL_NAME=lcd-ocr-detection
MLFLOW_OCR_MODEL_NAME=lcd-ocr-digits
# Set to true to load models from MLflow registry instead of local disk
USE_MLFLOW_REGISTRY=false
# Set to true to log inference metrics to MLflow
USE_MLFLOW_TRACKING=false

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_API_URL=http://localhost:8080/api/v1
AIRFLOW_DAG_ID=lcd_ocr_training
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
